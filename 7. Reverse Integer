class Solution:
    def reverse(self, x: int) -> int:
        if(x<0):
            a=str(abs(x))[::-1]
            b=int(a)
            if(b>=2**31):
                return 0
            else:
                return(-b)
        else:
            a=str(x)[::-1]
            if(int(a)>=2**31):
                return 0
            else:
                return int(a)
            
