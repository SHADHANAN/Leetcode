class Solution:
    def searchRange(self, nums: List[int], target: int) -> List[int]:
        l=[]
        i=0
        while(i<=len(nums)-1):
            if(nums[i]==target):
                l.append(i)
                i+=1
            else:
                i+=1
        if(len(l)>1):
            return [l[0],l[len(l)-1]]
        elif(len(l)==1):
            return [l[0],l[0]]
        else:
            return [-1,-1]
