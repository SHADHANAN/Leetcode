class Solution:
    def largestNumber(self, nums: List[int]) -> str:
        l1 = []
        for i in range(len(nums)):
            l1.append(str(nums[i]))
        for i in range(len(l1)):
            for j in range(len(l1) - 1):
                if l1[j] + l1[j + 1] < l1[j + 1] + l1[j]:
                    l1[j], l1[j + 1] = l1[j + 1], l1[j]

        ans = "".join(l1)

        if ans[0] == "0":
            return "0"

        return ans
